            detail_mouvements d1_0 
                on em1_0.id=d1_0.id_entete 
        left join
            articles a1_0 
                on a1_0.id=d1_0.id_article 
        left join
            entrepots e1_0 
                on e1_0.id=a1_0.entrepot_id 
        order by
            em1_0.date_mouvement desc
